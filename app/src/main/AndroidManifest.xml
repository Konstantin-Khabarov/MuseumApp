<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MuseumApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MuseumApp">
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.exhibits.ExhibitManagementActivity"
            android:exported="false" />
        <activity
            android:name=".ui.museums.MuseumManagementActivity"
            android:exported="false" />
        <activity
            android:name=".ui.authors.AuthorManagementActivity"
            android:exported="false" />
        <activity
            android:name=".ui.authors.AuthorDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.exhibits.ExhibitDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.museums.MuseumDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.exhibits.AddExhibitActivity"
            android:exported="false"
            android:label="Добавить экспонат"
            android:parentActivityName=".ui.exhibits.ExhibitManagementActivity" />
        <activity
            android:name=".ui.exhibits.EditExhibitActivity"
            android:exported="false"
            android:label="Редактировать экспонат"
            android:parentActivityName=".ui.exhibits.ExhibitDetailActivity" />
        <activity
            android:name=".ui.authors.AddAuthorActivity"
            android:exported="false"
            android:label="Добавить автора"
            android:parentActivityName=".ui.authors.AuthorManagementActivity" />
    </application>

</manifest>